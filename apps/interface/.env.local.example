# Copy to apps/interface/.env.local and fill in.
# Both keys are server-side only; they never reach the browser.

# Anthropic API key for reflective feedback (claude-sonnet-4-6).
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI API key for Whisper transcription (whisper-1).
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
